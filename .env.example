# zAgent Configuration
# Copy this file to .env and fill in your values.

# Required: OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Default model to use
# Examples: minimax/minimax-m2.5, openai/gpt-4o, google/gemini-2.5-pro
ZAGENT_DEFAULT_MODEL=minimax/minimax-m2.5

# Optional: Log directory for JSON trace files
# ZAGENT_LOG_DIR=./logs

# Optional: Session database directory
# ZAGENT_SESSION_DIR=~/.zagent

# Optional: SurrealDB remote session store
# SURREALDB_URL=ws://127.0.0.1:8000
# SURREALDB_USER=root
# SURREALDB_PASS=root
# SURREALDB_NS=zagent
# SURREALDB_DB=session_storage

# Optional: auto-apply latest DB migrations at startup
# Default: true in debug/dev builds, false in release builds
# ZAGENT_AUTO_MIGRATE_LATEST=true

# Optional: Rust log level filter (overrides --verbose flag)
# RUST_LOG=zagent=info,zagent_core=info,zagent_native=info

# Optional: OTLP tracing (requires `--features otel`)
# Example: http://localhost:4317
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=zagent
